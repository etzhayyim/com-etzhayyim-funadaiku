;; funadaiku 船大工 — sea_trial cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L5c: at-sea acceptance trials
{:cell/id "sea_trial"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_sea_trial"
 :cell/doc "L5c sea trials — performance (wind-assist efficiency, solar contribution, fuel-cell endurance, autonomy AI), stability, FFE (free-fall lifeboat), SOLAS compliance. IMO MASS Degree 3 remote ops window. Witness: classification surveyor."
 :cell/state-graph
 {:nodes [:trial-plan :performance-run :stability-test :safety-check]
  :entry :trial-plan
  :edges [[:trial-plan :performance-run] [:performance-run :stability-test]
          [:stability-test :safety-check] [:safety-check :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G4" "G5" "G6" "G10"]
 :cell/kotoba
 {:reads [:vessel/id :vessel/gnc-ready :wind-data/trial-window :survey-authority/did]
  :writes [:vessel/sea-trial-pass :vessel/performance-data :seaTrialRecord/id]}}
