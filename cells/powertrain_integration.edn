;; funadaiku 船大工 — powertrain_integration cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L4: zero-emission powertrain integration
{:cell/id "powertrain_integration"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_powertrain_integration"
 :cell/doc "L4 integration (THE defining zero-emission heart) — wind-assist rotor rig + solar array flash + H₂ fuel-cell stack + LFP battery module + electric azimuth pods + GNC autonomy. ATEX-zoned bay, H₂/N₂ purge. Green H₂ chain-of-custody mandatory (G8/G9). Settlement intent only."
 :cell/state-graph
 {:nodes [:wind-rig-install :solar-flash :fc-stack-mount :battery-connect :gnc-flash]
  :entry :wind-rig-install
  :edges [[:wind-rig-install :solar-flash] [:solar-flash :fc-stack-mount]
          [:fc-stack-mount :battery-connect] [:battery-connect :gnc-flash]
          [:gnc-flash :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G9"]
 :cell/kotoba
 {:reads [:vessel/id :powerplant/type :hydrogen-source/certification :solar-panel/wattage
          :battery-pack/capacity-kwh :pod/thrust-kw]
  :writes [:vessel/propulsion-ready :hydrogen-chain-of-custody :settlement-intent-id
           :powertrainIntegrationAttestation/id]}}
