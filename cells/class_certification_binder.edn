;; funadaiku 船大工 — class_certification_binder cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · terminal: ABS/DNV/ClassNK certificate binding
{:cell/id "class_certification_binder"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_class_certification_binder"
 :cell/doc "Terminal cell — binds sea-trial pass + decarbonization audit into class society certificate (ABS/DNV/ClassNK). Registers MMSI, IMO number, Class notation (with zero-emission green hull addendum). Stops at intent; real certificate issue is class society's gate."
 :cell/state-graph
 {:nodes [:gather-docs :verify-compliance :format-cert :registry-bind]
  :entry :gather-docs
  :edges [[:gather-docs :verify-compliance] [:verify-compliance :format-cert]
          [:format-cert :registry-bind] [:registry-bind :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G5" "G6" "G8"]
 :cell/kotoba
 {:reads [:vessel/id :vessel/sea-trial-pass :vessel/eexi-rating :vessel/cii-rating]
  :writes [:vessel/imo-number :vessel/mmsi :vessel/class-notation
           :silenCargoShipReview/id]}}
