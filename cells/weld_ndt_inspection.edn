;; funadaiku 船大工 — weld_ndt_inspection cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L3: NDT (RT/UT/PT) weld inspection
{:cell/id "weld_ndt_inspection"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_weld_ndt_inspection"
 :cell/doc "L3 NDT inspection — radiography (RT) / ultrasonic (UT) / penetrant (PT) testing on grand-block seams. Tsutsuki crawler witness (robot verification, G3). Pass/fail determination and rework routing."
 :cell/state-graph
 {:nodes [:plan-inspection :execute-ndt :analyze-results :rework-decision]
  :entry :plan-inspection
  :edges [[:plan-inspection :execute-ndt] [:execute-ndt :analyze-results]
          [:analyze-results :rework-decision] [:rework-decision :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3" "G5" "G6"]
 :cell/kotoba
 {:reads [:grand-block/id :grand-block/status :weld/id :weld/location]
  :writes [:grand-block/ndt-status :weld/pass :weld/rework
           :weldInspectionRecord/id]}}
