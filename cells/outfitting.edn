;; funadaiku 船大工 — outfitting cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L5a: mechanical/electrical outfitting
{:cell/id "outfitting"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_outfitting"
 :cell/doc "L5a outfitting — piping (fire / compressed-air / cooling-water / H₂ + N₂ purge), electrical harness, instrumentation, SCADA, navigation bridge, crew spaces. Otete-yard manipulator + open MEP schematics (FreeCAD)."
 :cell/state-graph
 {:nodes [:pipe-install :electrical-harness :instrumentation :scada-wiring]
  :entry :pipe-install
  :edges [[:pipe-install :electrical-harness] [:electrical-harness :instrumentation]
          [:instrumentation :scada-wiring] [:scada-wiring :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G2" "G5" "G6"]
 :cell/kotoba
 {:reads [:vessel/id :vessel/propulsion-ready :mep-schematic/id :instrumentation-spec/id]
  :writes [:vessel/outfitting-status :mep-verification :outfittingAttestation/id]}}
