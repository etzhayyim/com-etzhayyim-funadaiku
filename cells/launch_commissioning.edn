;; funadaiku 船大工 — launch_commissioning cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L5b: hull launch + systems commissioning
{:cell/id "launch_commissioning"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_launch_commissioning"
 :cell/doc "L5b launch & commissioning — hull launch sequence, fuel-cell cold-start, battery pack balance charging, GNC autonomy smoke-test, IMO MASS documentation (Degree 3 ops manual)."
 :cell/state-graph
 {:nodes [:launch-prep :float-check :fc-startup :battery-charge :gnc-smoke]
  :entry :launch-prep
  :edges [[:launch-prep :float-check] [:float-check :fc-startup]
          [:fc-startup :battery-charge] [:battery-charge :gnc-smoke]
          [:gnc-smoke :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G5" "G6" "G8"]
 :cell/kotoba
 {:reads [:vessel/id :vessel/outfitting-status :hydrogen-source/test-batch
          :battery-pack/state-of-charge]
  :writes [:vessel/floats :vessel/fc-commissioned :vessel/gnc-ready
           :launchCommissioningRecord/id]}}
