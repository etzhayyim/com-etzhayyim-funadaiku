;; funadaiku 船大工 — decarbonization_audit cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · cross-cell: lifecycle carbon audit (well-to-wake)
{:cell/id "decarbonization_audit"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_decarbonization_audit"
 :cell/doc "Cross-cell well-to-wake decarbonization audit per IMO GHG / EEXI / CII. Steel supply chain (CBAM + scrap % verification), hydrogen production (electrolysis CO₂-neutral verify), solar + wind + battery recycling EOL. MARPOL Annex VI + EEXI corridor. Stops at intent; real verification is skipper-operator responsibility."
 :cell/state-graph
 {:nodes [:steel-audit :hydrogen-eol :solar-eol :battery-eol :imo-report]
  :entry :steel-audit
  :edges [[:steel-audit :hydrogen-eol] [:hydrogen-eol :solar-eol]
          [:solar-eol :battery-eol] [:battery-eol :imo-report]
          [:imo-report :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G5" "G6" "G8" "G9"]
 :cell/kotoba
 {:reads [:vessel/id :steel-supply/eol-verification :hydrogen-source/co2-intensity
          :solar-panel/eol-recycling :battery-pack/eol-recycling]
  :writes [:vessel/eexi-rating :vessel/cii-rating :decarbonizationAudit/id]}}
