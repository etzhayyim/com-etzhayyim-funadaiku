;; funadaiku 船大工 — grand_block_assembly cell (langgraph, WASM runtime)
;; ADR-2606013400 · Phase 2 scaffold · L2: grand-block assembly from sub-blocks
{:cell/id "grand_block_assembly"
 :cell/glyph "船"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_grand_block_assembly"
 :cell/doc "L2 assembly — grand-block fabrication from sub-blocks (Oshidashi SPMT erection witness). Jig design, positioning, tack-welding, and fit-check. Zero-emission yard only (G8)."
 :cell/state-graph
 {:nodes [:jig-design :block-positioning :tack-weld :fit-check]
  :entry :jig-design
  :edges [[:jig-design :block-positioning] [:block-positioning :tack-weld]
          [:tack-weld :fit-check] [:fit-check :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3" "G5" "G6"]
 :cell/kotoba
 {:reads [:block/id :block/status :jig/id :jig/design]
  :writes [:grand-block/id :grand-block/status :grand-block/location
           :grandBlockAssemblyAttestation/id]}}
