  :robot/op-sequence ["block-lift" "transport" "align-on-dock" "tack-hold"]
  :robot/phase "R1+" :robot/maturity :design-only}

 {:robot/id "funadaiku.tsutsuki" :robot/glyph "突き" :robot/name "Tsutsuki — hull-seam NDT crawler (RT/UT/PT), weld witness"
