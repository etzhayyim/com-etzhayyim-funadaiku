[{:fleet/id "funadaiku.yard" :fleet/actor "actor:funadaiku" :fleet/adr "2606013400"
  :fleet/purpose "build zero-emission autonomous cargo ships (Nagi class)" :fleet/sourcing :representative}

 {:robot/id "funadaiku.ita-ori" :robot/glyph "板織" :robot/name "Ita-ori — panel-line / curved-block automated welder"
