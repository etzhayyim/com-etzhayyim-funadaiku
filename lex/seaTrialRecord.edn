;; com.etzhayyim.funadaiku.seaTrialRecord — lexicon (EDN form)
;; ADR-2606013400 · L5c at-sea acceptance trials
{:lexicon 1
 :id "com.etzhayyim.funadaiku.seaTrialRecord"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["vesselId" "trialDate" "windCondition" "result"]
    :properties
    {:vesselId {:type "string" :description "vessel DID"}
     :trialDate {:type "string" :description "ISO-8601 trial date"}
     :windCondition {:type "string" :description "Beaufort scale + gust info"}
     :windRigContribution {:type "number" :description "% thrust from wind-assist"}
     :solarContribution {:type "number" :description "% power from solar"}
     :hydrogenEndurance {:type "number" :description "hours at rated power"}
     :autonomyPerformance {:type "string" :description "GNC waypoint tracking, collision avoidance verify"}
     :stabilityTesting {:type "string" :description "heel angle, metacentric height verify"}
     :safetyEquipment {:type "string" :description "FFE free-fall lifeboat + SOLAS compliance"}
     :classificationSurveyor {:type "string" :description "surveyor DID + class society"}
     :result {:type "string" :description "PASS | REWORK | FAIL"}
     :timestamp {:type "string" :description "ISO-8601 record time"}}}}}}
