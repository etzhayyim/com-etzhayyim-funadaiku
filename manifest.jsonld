    "did:web:etzhayyim.com:hikari",
    "did:web:etzhayyim.com:kuni-umi"
  ],
  "surfaceCounterpartOf": "watatsumi (綿津見 submersible, ADR-2605252200)",
  "reusesGnc": "kami-autodrive VehicleClass::Ship — dynamics::ShipHydro (ADR-2606010600)",
  "referenceVessel": {
    "class": "Nagi 凪",
    "type": "coastal / short-sea zero-emission autonomous cargo carrier",
    "design": "data/vessel.edn",
    "dwt": 3000,
    "loaM": 90,
    "beamM": 15,
    "serviceSpeedKn": 10,
    "massAutonomyDegree": 3,
    "powertrain": "wind-assist (2x rotor/wing sail) + solar deck (~160 kWp) + PEM H2 fuel-cell (~2x1.2 MW) + LFP battery (~2 MWh) + 2x1.5 MW electric azimuth pods; NO fossil engine"
  },
  "shipyard": {
    "design": "data/shipyard.edn",
    "sbom": "data/building.edn",
    "method": "modular grand-block / block-erection (inherited from watatsumi), surface-hull scale",
    "modelledIn": "kami-engine + kotoba EAVT (giemon-factory pattern, ADR-2606010030)"
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Zero-emission autonomous surface cargo ships, coastal / short-sea scale",
    "inScope": [
      "Coastal / short-sea general-cargo carriers — Nagi 凪 class ≤5000 DWT (G12)",
      "Inland / harbour zero-emission freight craft",
      "Wind-assist + solar + hydrogen fuel-cell + LFP hybrid powertrain integration",
      "IMO MASS Degree 3 (remote-controlled, no crew) autonomy baseline"
    ],
    "deferredToR3PlusViaCouncil": [
      "Ocean short-sea cargo at upper G12 cap (full class + MASS Degree 3 + green-H2 bunkering)",
      "Ammonia / methanol fuel-cell variants (green chain-of-custody, G14)"
    ],
    "exclusions": [
      "Naval / armed vessels (N1)",
      "Nuclear propulsion (N2)",
      "Military stealth / grey-hull / low-observable (N3)",
      "Warship hull forms / naval-auxiliary primary design (N4)",
      "Fossil-fuel main or auxiliary propulsion — HFO/MGO/diesel/LNG-as-fuel (N5)",
      "Flag-of-convenience tax-avoidance engineering (N6)",
      "IUU-fishing support / ocean dumping / at-sea incineration (N7)",
      "Beaching-yard ship-breaking (N8)",
      "Ballast-water invasive-species transfer (N9)",
      "MASS Degree 4 fully-unmanned without Council review (N10)",
      "Dark-fleet / sanctions-evasion operation (N11)",
      "Speed-record / vanity priority over efficiency (N12)"
    ]
  },
  "roboticsClasses": [
    "Ita-ori (板織) — panel-line / curved-block automated welder (R1+)",
    "Oshidashi (押出) — grand-block transport + erection crane SPMT (R1+)",
    "Tsutsuki (突き) — hull-seam NDT crawler (RT/UT/PT), weld witness (R1+; inherits watatsumi Tako)",
    "Nuri-de (塗手) — hull coating / blasting robot, VOC-bounded (R2+)",
    "Otete-yard — kuni-umi Otete arm for outfitting + powertrain bay (R1+)"
  ],
